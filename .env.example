# GEMINI_API_KEY: Required for Gemini AI API calls when using Gemini as a backup to Ollama.
# Set in `.env.local` or your shell; do not commit real keys.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public base URL when the app is deployed (optional for local dev).
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Ollama chat model (`/api/generate`). If unset, a Gemma 4 tag is chosen from RAM/VRAM + CPU/GPU
# (see src/server/gemma4-hardware.ts and GET /api/system/llm-capacity). Set this to pin a model.
# OLLAMA_MODEL="gemma4:26b-a4b-it-q4_K_M"
# Docker Compose often sets OLLAMA_MODEL explicitly (e.g. nemotron-cascade-2) — override there too.

# Ollama /api/generate: max wait in ms (abort after this). Responses return as soon as ready—
# this is not a fixed delay. Default 300000 (5 min) for big models; small models finish in seconds.
OLLAMA_GENERATE_TIMEOUT_MS=300000

# Ollama /api/embeddings model for semantic news↔Kalshi market matching. Use off or none to disable (token overlap only).
OLLAMA_EMBED_MODEL="nomic-embed-text"
# OLLAMA_EMBED_TIMEOUT_MS=60000
# KALSHI_EMBED_CONCURRENCY=4
# KALSHI_EMBED_MAX_MARKETS=4000

# Half-life in days for recency weighting of trade ratings per RSS source (exponential decay).
SOURCE_RATING_HALF_LIFE_DAYS=14
# Blend prior source/reasoning score with observed avg until this many CLOSED rated trades per key.
# SOURCE_RATING_PRIOR_MIN_TRADES=5

# Trade decisions are AI-driven (shouldTrade + curated tickers). BASE/DYNAMIC threshold env vars are unused; TRADE_BOOTSTRAP_UNTIL_RATED still flags early phase in the LLM prompt.
# BASE_TRADE_THRESHOLD=74
# BASE_TRADE_THRESHOLD_BOOTSTRAP=58
# TRADE_BOOTSTRAP_UNTIL_RATED=8
# DYNAMIC_THRESHOLD_FLOOR=62
# DYNAMIC_THRESHOLD_FLOOR_BOOTSTRAP=52
# DYNAMIC_THRESHOLD_CEIL=92

# RSS: after a fetch error, skip monitor cycles with skips = min(cap, 2^streak - 1); streak resets on
# success or after RSS_BACKOFF_RESET_MS (default 72h).
# RSS_BACKOFF_RESET_MS=259200000
# RSS_BACKOFF_MAX_SKIP_CYCLES=63

# Related headlines shown to the LLM (token overlap % + time proximity). Tune overlap vs false links.
# NEWS_RELATED_MIN_OVERLAP_PCT=38
# NEWS_RELATED_MAX_DELTA_MS=172800000
# NEWS_RELATED_MAX_LINKS=5
# NEWS_RELATED_LOOKBACK=400

# Kalshi WebSocket + signed REST (optional). Generate keys at https://kalshi.com/account/profile — save the PEM once.
# WS connects when BOTH are set; subscribes to ticker updates for markets in OPEN simulated positions.
# https://docs.kalshi.com/getting_started/quick_start_websockets
# KALSHI_ACCESS_KEY_ID=your_key_id
# KALSHI_PRIVATE_KEY_PATH=C:\path\to\kalshi-key.pem
# Or PEM with escaped newlines (Docker-friendly): KALSHI_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2
# Max tickers on one WS ticker subscription (OPEN positions always kept; watchlist fills remaining slots).
# KALSHI_WS_MAX_SUBSCRIBED_TICKERS=200

# Local CouchDB credentials for docker-compose.
COUCHDB_USER="admin"
COUCHDB_PASSWORD="password"

# Kalshi taker fee coefficient in simulated cost (default 0.07 = 7% in P×(1−P) formula). See Kalshi fee schedule.
# KALSHI_TAKER_FEE_COEFFICIENT=0.07

# Kalshi public API (open markets list + market quotes). Legacy host redirects to elections API.
# KALSHI_API_BASE="https://api.elections.kalshi.com/trade-api/v2"
# KALSHI_MARKETS_MAX_TOTAL=8000
# Full open-market list refresh (default 20 min). Raise if you still see 429.
# KALSHI_MARKETS_REFRESH_MS=1200000
# Refresh Kalshi market JSON for each OPEN position ticker (default 60s; min 15s).
# KALSHI_OPEN_POSITION_REFRESH_MS=60000
# After each refresh, ask the LLM for discretionary early exits (default on).
# AI_EXIT_REVIEW_ENABLED=true
# CouchDB chunk size for kalshi_markets docs (default 450).
# KALSHI_DB_CHUNK_SIZE=450
# KALSHI_CURATED_MARKETS_FOR_LLM=35
# Rate limiting: min ms between Kalshi requests; 429 retries with backoff (Retry-After honored).
# KALSHI_MIN_INTERVAL_MS=300
# KALSHI_MAX_RETRIES=8
# KALSHI_429_BACKOFF_CAP_MS=120000
